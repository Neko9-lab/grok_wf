{
  "name": "gwf-cli",
  "version": "0.1.0",
  "description": "Grok Workflow Framework CLI — init AI coding workflow in any project for Grok Build",
  "type": "module",
  "bin": {
    "gwf": "./bin/gwf.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-templates.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js 2>nul || node --test dist/lib/*.test.js 2>nul || echo \"no unit tests yet\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "grok",
    "gwf",
    "ai",
    "workflow",
    "coding-agent",
    "cli",
    "grok-build"
  ],
  "author": "Neko9-lab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neko9-lab/grok_wf.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Neko9-lab/grok_wf/issues"
  },
  "homepage": "https://github.com/Neko9-lab/grok_wf#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
